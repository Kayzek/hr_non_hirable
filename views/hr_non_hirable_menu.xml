<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Filtered action: Non-Hirable Employees dashboard -->
    <record id="action_hr_non_hirable_employees" model="ir.actions.act_window">
        <field name="name">Non-Hirable Employees</field>
        <field name="res_model">hr.employee</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('is_non_hirable', '=', True)]</field>
        <field name="context">{'search_default_is_non_hirable': 1, 'active_test': False}</field>
        <field name="view_id" ref="hr_non_hirable_employee_view_tree"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No non-hirable employees.
            </p>
            <p>
                Employees flagged as non-hirable will appear here.
                You can flag an employee during the departure process
                or manually from their profile.
            </p>
        </field>
    </record>

    <!-- Search view for the dashboard -->
    <record id="hr_employee_view_search_non_hirable" model="ir.ui.view">
        <field name="name">hr.employee.search.non_hirable</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_filter"/>
        <field name="arch" type="xml">
            <xpath expr="//search" position="inside">
                <filter name="is_non_hirable"
                        string="Non-Hirable"
                        domain="[('is_non_hirable', '=', True)]"/>
            </xpath>
            <xpath expr="//group" position="inside">
                <filter name="group_non_hirable"
                        string="Non-Hirable"
                        context="{'group_by': 'is_non_hirable'}"/>
            </xpath>
        </field>
    </record>

    <!-- Menu item at HR root level, before Configuration -->
    <menuitem id="menu_hr_non_hirable"
              name="Non-Hirable Employees"
              parent="hr.menu_hr_root"
              sequence="50"
              groups="hr.group_hr_manager"/>

    <!-- Submenu for Non-Hirable Employees -->
    <menuitem id="menu_hr_non_hirable_employees"
              name="Employees"
              parent="menu_hr_non_hirable"
              action="action_hr_non_hirable_employees"
              sequence="10"/>

    <!-- Submenu for Non-Hirable Reasons -->
    <menuitem id="menu_hr_non_hirable_reasons"
              name="Reasons"
              parent="menu_hr_non_hirable"
              action="hr_non_hirable_reason_action"
              sequence="20"/>

</odoo>
